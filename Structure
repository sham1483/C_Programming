#include<stdio.h>
#pragma pack(1)

    struct Demo //Decleration
    {
        int i;  
        char ch;    
        float f;   
    };
    
int main()
{
   struct Demo dobj;    //object

    dobj.i=11;
    dobj.ch='A';
    dobj.f=10.0f;

   printf("%d\n",dobj.i);     //11
   printf("%c\n",dobj.ch);   //A
   printf("%f\n",dobj.f);   //10.000


   return 0;
    
}
