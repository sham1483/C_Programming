#include<stdio.h>


    int no = 11;    //Globle Variable (Data)

    void fun()
    {
        int i = 51; //Local Variable (Stack)

        printf("inaide fun:%d\n",i); //51
        printf("inside fun:%d\n",no); //11

    }
    
int main()
{
       int i = 21; //Local Variable (Stack)

        printf("inaide main:%d\n",i); //21
        printf("inside main:%d\n",no); //11

        fun();

   return 0;
    
}
